# ═══════════════════════════════════════════════════════════════════
# Bike Router — пример окружения
# Скопируйте в .env и отредактируйте под свой сервер / город.
# ═══════════════════════════════════════════════════════════════════

# --- Обязательность переменных ---
# Для запуска API ни одна переменная не обязательна: есть значения по умолчанию.
#
# Режим «только коридор по POST» (динамический граф между точками ± CORRIDOR_BUFFER_METERS или ± BUFFER):
#   • GRAPH_CORRIDOR_MODE=true
#   • НЕ задавайте AREA_POLYGON_WKT и НЕ задавайте ненулевой AREA_* — иначе коридор отключится.
#   • Приоритет в коде: AREA_POLYGON_WKT → AREA_* → GRAPH_CORRIDOR_MODE → demo START/END+BUFFER.
#
# Фиксированная зона города:
#   • задайте AREA_* и/или AREA_POLYGON_WKT; GRAPH_CORRIDOR_MODE оставьте false или не задавайте.
#
# Docker: при необходимости BIKE_ROUTER_BASE_DIR=/data (в compose уже /data).

# --- Каталог данных (кэш тайлов, OSMnx, дисковые кэши) ---
# BIKE_ROUTER_BASE_DIR=/data

# --- Режим коридора (граф и спутник по точкам POST ± BUFFER) ---
GRAPH_CORRIDOR_MODE=true
# Готовые взвешенные графы коридоров в cache/corridor_graphs/*.graphml (ключ: bbox + настройки зелени/весов).
# CORRIDOR_GRAPH_DISK_CACHE=true
# Сетка для ключа кэша коридора (~0.001° ≈ 111 м по широте; в коде по умолчанию 0.001). 0 — только round(..., 6).
# CORRIDOR_CACHE_GRID_STEP_DEG=0.001

# Без фиксированной области (обязательно для работы коридора):
AREA_MIN_LAT=0
AREA_MAX_LAT=0
AREA_MIN_LON=0
AREA_MAX_LON=0
# AREA_POLYGON_WKT не задавать

# --- Фиксированная область (отключите коридор: GRAPH_CORRIDOR_MODE=false) ---
# 1) Полигон WKT (lon lat), приоритет над AREA_*:
# AREA_POLYGON_WKT=POLYGON ((50.08 53.18, 50.22 53.18, 50.22 53.26, 50.08 53.26, 50.08 53.18))
#
# 2) Прямоугольник:
# AREA_MIN_LAT=53.18
# AREA_MAX_LAT=53.26
# AREA_MIN_LON=50.08
# AREA_MAX_LON=50.22

# Демо START/END — для коридора на форму графа не влияют; без коридора и без AREA — bbox вокруг этой пары.
START_LAT=53.186243
START_LON=50.088031
END_LAT=53.195334
END_LON=50.124063
BUFFER=0.003
# При GRAPH_CORRIDOR_MODE по умолчанию в коде 400 м (см. config). Явно задать или переопределить:
CORRIDOR_BUFFER_METERS=400
# Поставьте 0, если нужен только BUFFER в градусах (лог: ±BUFFER=…°).

# --- Лимиты маршрутизации ---
# MAX_ROUTE_KM=50
# MAX_SNAP_DISTANCE_M=500

# --- Инвалидация кэшей (маршруты + графы коридоров включают отпечаток весов) ---
# ROUTING_ALGO_VERSION=1

# --- Кэши ---
# GEOCODE_DISK_CACHE=true
# ROUTE_DISK_CACHE=true
# CACHE_SATELLITE=true
# CACHE_TILE_ANALYSIS=true
# FORCE_RECALCULATE=false

# --- Спутниковый анализ (озеленение) ---
# SATELLITE_ZOOM=17
# ROAD_BUFFER_METERS=10
# ANALYZE_CORRIDOR=true
# TILE_DOWNLOAD_THREADS=8
# TMS_SERVER=google
# DISABLE_SATELLITE_GREEN=false

# --- HTTP (production) ---
# Список origin через запятую; по умолчанию — * (dev). При явных origin включается allow_credentials.
# CORS_ALLOW_ORIGINS=https://example.com,https://www.example.com

# --- Локальный запуск (python -m bike_router) ---
# По умолчанию в коде: 0.0.0.0 — доступ с телефона в LAN: http://<ipconfig IPv4>:8000
# BIKE_ROUTER_PORT=8000
# Только с этого ПК (без LAN):
# BIKE_ROUTER_HOST=127.0.0.1
