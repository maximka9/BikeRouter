# ─────────────────────────────────────────────
# BikeRouter local config (рабочий; коэффициенты моделей — в Python-коде)
# ─────────────────────────────────────────────

# Данные и кэши
BIKE_ROUTER_BASE_DIR=

# Сервер
BIKE_ROUTER_HOST=127.0.0.1
BIKE_ROUTER_PORT=8000
CORS_ALLOW_ORIGINS=*

# Демо-маршрут / batch experiments
START_LAT=53.186243
START_LON=50.088031
END_LAT=53.195334
END_LON=50.124063

# Основной режим графа
GRAPH_CORRIDOR_MODE=true
BUFFER=0.003
CORRIDOR_BUFFER_METERS=400
CORRIDOR_BUFFER_EXPAND_SCHEDULE=10,100,1000,5000

# Фиксированная зона, если понадобится
AREA_MIN_LAT=0
AREA_MAX_LAT=0
AREA_MIN_LON=0
AREA_MAX_LON=0
AREA_POLYGON_WKT=

# Area precache
PRECACHE_AREA_ENABLED=true
PRECACHE_AREA_NAME=samara_polygon
PRECACHE_AREA_USE_GREEN_GRAPH=true
PRECACHE_AREA_POLYGON_WKT=POLYGON ((50.08529663085938 53.19616119954287, 50.06546974182129 53.173685114216816, 50.115680694580085 53.180218280023055, 50.163402557373054 53.17054678321688, 50.195331573486335 53.170752582446326, 50.19447326660157 53.20109715974551, 50.20065307617188 53.23316704834061, 50.15430450439453 53.228440304465984, 50.08529663085938 53.19616119954287))

# Спутниковый анализ
DISABLE_SATELLITE_GREEN=false
ANALYZE_CORRIDOR=true
SATELLITE_ZOOM=20
ROAD_BUFFER_METERS=10
TILE_DOWNLOAD_THREADS=16
GREEN_TILE_BATCH_SIZE=4096
TMS_SERVER=google

# Overpass
OSM_OVERPASS_URLS=https://overpass-api.de/api,https://overpass.kumi.systems/api
OSM_REQUESTS_TIMEOUT=180
OSM_OVERPASS_FIRST_TIMEOUT=20
OSM_OVERPASS_RATE_LIMIT=false

# Кэши
ROUTE_DISK_CACHE=false
CORRIDOR_GRAPH_DISK_CACHE=true
GEOCODE_DISK_CACHE=true
CACHE_SATELLITE=true
CACHE_TILE_ANALYSIS=true
FORCE_RECALCULATE=false

# Лимиты маршрутов
MAX_ROUTE_KM=50
MAX_SNAP_DISTANCE_M=500

# Runtime ML surface predictions
SURFACE_AI_RUNTIME_ENABLED=True
SURFACE_AI_RUNTIME_PREDICTIONS_PATH=cache/surface_ai/runtime_predictions.csv
SURFACE_AI_RUNTIME_STRICT=false

# Surface AI experiment output
SURFACE_AI_OUTPUT_MODE=compact
SURFACE_AI_MAX_OUTPUT_FILES=20
SURFACE_AI_COMPACT_CLEANUP=true
SURFACE_AI_SAVE_HEAVY_ARTIFACTS=false
SURFACE_AI_COMPACT_ALLOWED_EXTENSIONS=.csv,.xlsx,.png
SURFACE_AI_SAVE_FULL_PREDICTIONS_GEOJSON=false

# Surface AI train/predict areas
SURFACE_AI_TRAIN_AREA_MODE=tile_coverage
SURFACE_AI_PREDICT_AREA_MODE=precache_polygon
SURFACE_AI_TRAIN_ON_ALL_TILE_EDGES=true
SURFACE_AI_PREDICT_ONLY_INSIDE_POLYGON=true
SURFACE_AI_TRAIN_GRAPH_SOURCE_PRIORITY=tile_coverage_graph,area_precache,osmnx_fallback
SURFACE_AI_PREDICT_GRAPH_SOURCE_PRIORITY=area_precache,tile_coverage_graph,osmnx_fallback
SURFACE_AI_OSMNX_RETAIN_ALL=true
SURFACE_AI_OSMNX_TRUNCATE_BY_EDGE=true
SURFACE_AI_OSMNX_SIMPLIFY=true
SURFACE_AI_OSMNX_NETWORK_TYPE=all
SURFACE_AI_OSMNX_CUSTOM_FILTER=

# Surface AI target/model selection
SURFACE_AI_CONCRETE_TARGET_MODE=compact
SURFACE_AI_GROUP_TARGET_MODE=3class_unpaved_hard_to_soft
SURFACE_AI_TRAIN_DIRECT_GROUP_MODEL=true
SURFACE_AI_SELECTION_METRIC=macro_f1_safe
SURFACE_AI_GROUP_SELECTION_METRIC=macro_f1_safe_rough_aware
SURFACE_AI_DANGEROUS_ERROR_PENALTY=0.5
SURFACE_AI_MIN_BAD_SURFACE_RECALL=0.5
SURFACE_AI_MIN_PAVED_ROUGH_RECALL=0.25
SURFACE_AI_PAVED_ROUGH_RECALL_WEIGHT=0.25
SURFACE_AI_UNPAVED_SOFT_RECALL_WEIGHT=0.25
SURFACE_AI_GROUP_CLASS_WEIGHT_MODE=balanced_manual
SURFACE_AI_GROUP_CLASS_WEIGHT_PAVED_GOOD=1.0
SURFACE_AI_GROUP_CLASS_WEIGHT_PAVED_ROUGH=4.0
SURFACE_AI_GROUP_CLASS_WEIGHT_UNPAVED_SOFT=3.0
SURFACE_AI_GROUP_THRESHOLD_TUNING=true
SURFACE_AI_PAVED_ROUGH_MIN_PROBA=0.30
SURFACE_AI_UNPAVED_SOFT_MIN_PROBA=0.35
SURFACE_AI_MODEL_CANDIDATES=always_majority,highway_heuristic,osm_only_rf,satellite_only_rf,combined_rf,combined_rf_balanced,combined_rf_without_spatial_prior,combined_rf_balanced_without_spatial_prior,combined_rf_with_neighbors
SURFACE_AI_GROUP_MODEL_CANDIDATES=group_direct_always_majority,group_direct_highway_heuristic,group_direct_osm_only_rf,group_direct_satellite_only_rf,group_direct_combined_rf,group_direct_combined_rf_balanced,group_direct_combined_rf_calibrated,group_direct_combined_rf_without_spatial_prior,group_direct_combined_rf_balanced_without_spatial_prior,group_direct_combined_rf_neighbor_features,group_direct_combined_rf_class_weight_manual,group_direct_combined_rf_paved_rough_oversampled,group_direct_combined_rf_threshold_tuned

# Surface AI calibration/safety
SURFACE_AI_CALIBRATION_ENABLED=true
SURFACE_AI_CALIBRATION_METHOD=sigmoid
SURFACE_AI_CALIBRATION_SHARE=0.1
SURFACE_AI_CALIBRATION_MIN_CLASS_COUNT=20
SURFACE_AI_MIN_CONFIDENCE=0.65
SURFACE_AI_CONF_HIGH=0.85
SURFACE_AI_CONF_MEDIUM=0.65
SURFACE_AI_ENABLE_SAFETY_POLICY=true
SURFACE_AI_PAVED_GOOD_MIN_CONFIDENCE=0.90
SURFACE_AI_BAD_SURFACE_MIN_CONFIDENCE=0.60
SURFACE_AI_MIN_MARGIN=0.15
SURFACE_AI_MAX_DANGEROUS_UPGRADE_RATE_EFFECTIVE=0.10
SURFACE_AI_MAX_CALIBRATION_ECE=0.08

# Surface AI leakage/tile features
SURFACE_AI_RUN_HOLDOUT_LEAKAGE_CHECKS=true
SURFACE_AI_HOLDOUT_SPLIT_MODE=grouped_geometry_or_way
SURFACE_AI_HOLDOUT_PREDICT_POLYGON_KNOWN_SHARE=0.2
SURFACE_AI_HOLDOUT_LARGE_GRID_M=1000
SURFACE_AI_MASK_HOLDOUT_LABELS_FOR_NEIGHBORS=true
SURFACE_AI_PREVENT_DIRECTED_EDGE_LEAKAGE=true
SURFACE_AI_USE_NEIGHBOR_FEATURES=true
SURFACE_AI_NEIGHBOR_HOPS=2
SURFACE_AI_NEIGHBOR_USE_PREDICTION_PASS2=true
SURFACE_AI_USE_SATELLITE_FEATURES=true
SURFACE_AI_SAMPLE_STEP_M=7
SURFACE_AI_PIXEL_WINDOW=5
SURFACE_AI_TMS_SERVER=google
SURFACE_AI_TILE_ZOOM=20
SURFACE_AI_TILES_DIR=
SURFACE_AI_TILE_EDGE_MATCH_MODE=samples_and_buffer
SURFACE_AI_EDGE_TILE_BUFFER_M=10
SURFACE_AI_TILE_USAGE_REPORT=true
SURFACE_AI_AUTO_PARALLEL=true
