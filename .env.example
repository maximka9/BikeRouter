# ═══════════════════════════════════════════════════════════════════
# Bike Router — .env для area precache внутри полигона
# Цель: corridor mode + заранее собранный area cache по полигону
# ═══════════════════════════════════════════════════════════════════

# --- Каталог данных ---
# Если переменную не задавать: кэш в подкаталоге репозитория bike_router/data/ (cache, osmnx_cache).
# Две папки на диске бывают, когда здесь R:\data, а дефолт пишет в bike_router/data — задайте ОДИН путь.
# Docker: в compose задают BIKE_ROUTER_BASE_DIR=/data (см. docker-compose.yml).
# Локально пусто = каталог данных bike_router/data/ (см. config.Settings).
# Неверно: /data на Windows часто превращается в R:\\data вместо репозитория.
BIKE_ROUTER_BASE_DIR=

# --- Основной режим: только коридор ---
GRAPH_CORRIDOR_MODE=true

# Фиксированную зону НЕ включать, иначе отключится dynamic corridor graph
AREA_MIN_LAT=0
AREA_MAX_LAT=0
AREA_MIN_LON=0
AREA_MAX_LON=0
# AREA_POLYGON_WKT не задавать

# --- Area precache (граф по PRECACHE_AREA_POLYGON_WKT; отдельно от corridor_graphs) ---
# Данные: {BIKE_ROUTER_BASE_DIR}/cache/area_precache/<hash>/ — в git не коммитить (см. .gitignore: data/).
# Идемпотентность: при обрыве удалите *.tmp в этой папке или перезапустите precache_area.
# Сборка только офлайн: python -m bike_router.tools.precache_area (до docker compose up).
PRECACHE_AREA_ENABLED=true
PRECACHE_AREA_NAME=samara_polygon
PRECACHE_AREA_USE_GREEN_GRAPH=true

PRECACHE_AREA_POLYGON_WKT=POLYGON ((50.08529663085938 53.19616119954287, 50.06546974182129 53.173685114216816, 50.115680694580085 53.180218280023055, 50.163402557373054 53.17054678321688, 50.195331573486335 53.170752582446326, 50.19447326660157 53.20109715974551, 50.20065307617188 53.23316704834061, 50.15430450439453 53.228440304465984, 50.08529663085938 53.19616119954287))

# --- Corridor параметры ---
BUFFER=0.003
# База для fingerprint; основная логика — CORRIDOR_BUFFER_EXPAND_SCHEDULE (последовательные буферы при NO_PATH).
CORRIDOR_BUFFER_METERS=400
CORRIDOR_BUFFER_EXPAND_SCHEDULE=10,100,1000,5000

# --- Demo START/END ---
START_LAT=53.186243
START_LON=50.088031
END_LAT=53.195334
END_LON=50.124063

# --- Спутниковый анализ ---
DISABLE_SATELLITE_GREEN=false
ANALYZE_CORRIDOR=true
ROAD_BUFFER_METERS=10
TILE_DOWNLOAD_THREADS=16
# Пакеты тайлов для зелени (меньше — меньше RAM при precache / большом полигоне). 0 = без разбиения.
GREEN_TILE_BATCH_SIZE=4096
# google — по умолчанию в config; при недоступности mt.google.com по DNS используйте esri
TMS_SERVER=google

# Если хочешь явно зафиксировать zoom, раскомментируй:
# SATELLITE_ZOOM=19

# --- Кэши ---
GEOCODE_DISK_CACHE=true
# Опциональный UX-кэш JSON ответов; не обязателен для корректности маршрутов.
ROUTE_DISK_CACHE=false
CACHE_SATELLITE=true
CACHE_TILE_ANALYSIS=true
FORCE_RECALCULATE=false
# green_edges/*.pkl: смена схемы в коде инвалидирует старые файлы; при «залипших» нулях — удалить cache/green_edges/
# или FORCE_RECALCULATE=true. GREEN_EDGE_REJECT_ALL_ZERO_CACHE=false — доверять полностью нулевому pickle (редко).

# --- Overpass ---
# Порядок важен: при сбое первого идёт следующий. overpass-api.de обычно стабильнее частных зеркал.
OSM_OVERPASS_URLS=https://overpass-api.de/api,https://overpass.kumi.systems/api
OSM_OVERPASS_RATE_LIMIT=false
OSM_REQUESTS_TIMEOUT=180
OSM_OVERPASS_FIRST_TIMEOUT=20
OVERPASS_PER_ENDPOINT_RETRIES=2

# --- Лимиты ---
MAX_ROUTE_KM=50
MAX_SNAP_DISTANCE_M=500

# --- Тепловая маршрутизация: погода × микроклимат рёбер (см. services/routing, services/weather) ---
# Усиление эффекта между контрастными днями в батч-эксперименте; подберите под регион.
HEAT_HOT_TREE_BONUS_SCALE=1.45
HEAT_HOT_OPEN_SKY_PENALTY_SCALE=1.55
HEAT_COLD_BUILDING_CANYON_BONUS_SCALE=1.4
HEAT_COLD_TREE_BONUS_DAMPING=0.65
HEAT_WEATHER_RESPONSE_SCALE=1.35

# Непрерывная тепло-микроклиматическая модель рёбер (без hot/cold/neutral).
# HEAT_TEMP_COOL_REF выше 10 °C — cold_like_norm заметнее в межсезонье.
# covered/tunnel — бонус; дождь в первую очередь через открытость, здания, покрытие, ветер.
HEAT_CONTINUOUS_ENABLE=true
HEAT_TEMP_REF_MAX=30
HEAT_TEMP_COOL_REF=14
HEAT_TEMP_COOL_RANGE=10
HEAT_RAIN_REF_MAX=3.0
HEAT_WIND_REF_MAX=12.0
HEAT_GUST_DELTA_REF_MAX=10.0
HEAT_TREE_SHADE_TEMP_GAIN=0.42
HEAT_TREE_SHADE_RAIN_DAMP=0.35
HEAT_TREE_SHADE_COLD_DAMP=0.58
HEAT_OPEN_SKY_TEMP_GAIN=0.52
HEAT_OPEN_SKY_WIND_GAIN=0.28
HEAT_OPEN_SKY_GUST_GAIN=0.22
HEAT_OPEN_SKY_HUMID_GAIN=0.18
# Ощущаемая температура (AT): Teff для heat; усиление open-sky / tree / КВ.
HEAT_APPARENT_TEMP_ENABLE=true
HEAT_APPARENT_TEMP_REF=25
HEAT_APPARENT_TEMP_HOT_REF=32
HEAT_APPARENT_TEMP_EXTREME_REF=38
HEAT_OPEN_SKY_APPARENT_GAIN=0.30
HEAT_OPEN_SKY_RADIATION_GAIN=0.25
HEAT_OPEN_SKY_HOT_EXTRA_GAIN=0.15
HEAT_EXTREME_APPARENT_THRESHOLD=35
HEAT_EXTREME_ROUTE_BETA_GAIN=0.30
HEAT_EXTREME_OPEN_ROUTE_GAIN=0.22
HEAT_EXTREME_TREE_ROUTE_GAIN=0.18
HEAT_TREE_SHADE_APPARENT_GAIN=0.38
HEAT_TREE_SHADE_RADIATION_GAIN=0.30
HEAT_TREE_SHADE_EXTREME_GAIN=0.20
HEAT_BUILDING_SHADE_RADIATION_GAIN=0.14
HEAT_BUILDING_SHADE_WIND_GAIN=0.32
HEAT_BUILDING_SHADE_GUST_GAIN=0.22
HEAT_BUILDING_SHADE_RAIN_GAIN=0.30
HEAT_BUILDING_SHADE_HUMID_GAIN=0.14
HEAT_COVERED_RAIN_GAIN=0.28
HEAT_COVERED_WIND_GAIN=0.14
HEAT_COVERED_GUST_GAIN=0.12
HEAT_WET_SURFACE_RAIN_GAIN=0.38
HEAT_WET_SURFACE_HUMID_GAIN=0.22
# HEAT_EDGE_K_OPEN / HEAT_EDGE_K_TREE — основной рычаг геометрии теплового маршрута.
# HEAT_EDGE_K_COVERED — вторичный бонус (укрытия в графе часто почти нет).
HEAT_EDGE_K_OPEN=0.66
HEAT_EDGE_K_TREE=0.54
HEAT_EDGE_K_BUILDING=0.50
HEAT_EDGE_K_COVERED=0.16
HEAT_EDGE_K_WET=0.34
HEAT_EDGE_K_WIND=0.36
HEAT_EDGE_RAIN_OPEN_MULT=0.48
HEAT_EDGE_RAIN_BUILDING_MULT=0.56
HEAT_EDGE_RAIN_WIND_EXP_MULT=0.22
HEAT_WIND_EXP_W1=0.45
HEAT_WIND_EXP_W2=0.35
HEAT_WIND_EXP_W3=0.35
HEAT_WET_SURFACE_EDGE_BAD_MAX=0.85
HEAT_OPEN_WET_SYNERGY=0.14
HEAT_WIND_OPEN_GAIN=0.34
HEAT_WIND_OPEN_GUST_EXTRA=0.24
# Ветер с направлением (° в снимке из Open-Meteo или вручную: метеоконвенция «откуда дует»).
# Если направления нет — автоматически omni-модель (как раньше).
HEAT_WIND_ALONG_OPEN_AMP=0.28
HEAT_WIND_CROSS_BUILD_AMP=0.35
HEAT_WIND_ALONG_BUILD_DAMP=0.24
STRESS_WIND_ALONG_OPEN_AMP=0.32
STRESS_WIND_CROSS_SHELTER_AMP=0.40
HEAT_EDGE_FACTOR_MIN=0.65
HEAT_EDGE_FACTOR_MAX=1.75
HEAT_COEFF_CLAMP_LO=0.72
HEAT_COEFF_CLAMP_HI=1.60
HEAT_COEFF_SOFT_OVERFLOW_GAIN=0.18
HEAT_COEFF_HARD_HI=1.85

# Погодный stress: часть глобального wm.stress + edge-specific (routing.weather_edge_stress_factor).
WEATHER_STRESS_GLOBAL_BLEND=0.28
WEATHER_STRESS_EDGE_RAIN_SLIP=0.22
WEATHER_STRESS_EDGE_WIND_OPEN=0.20
WEATHER_STRESS_EDGE_LTS_FAST=0.17
WEATHER_STRESS_EDGE_BUILDING_SHELTER=0.11
WEATHER_STRESS_EDGE_FACTOR_MIN=0.82
WEATHER_STRESS_EDGE_FACTOR_MAX=1.48
# Физика: дождевой штраф по типу покрытия (асфальт почти без изменений).
WEATHER_PHYS_WET_PENALTY_TIER0_CAP=0.016
WEATHER_PHYS_WET_PENALTY_TIER1_COEF=0.048
WEATHER_PHYS_WET_PENALTY_TIER2_COEF=0.12

# --- Сезон маршрутизации и снег (Open-Meteo: snowfall см/ч, snow_depth м, weather_code) ---
# Календарь по умолчанию — север умеренных широт; «зелёный сезон» не обязан совпадать с календарной весной.
# Ранняя весна: до SEASON_EARLY_SPRING_END_DAY апреля; плавное включение зелени SEASON_GREEN_RAMP_*.
SEASON_GREEN_RAMP_START_DAY=10
SEASON_GREEN_RAMP_END_DAY=20
SEASON_EARLY_SPRING_END_DAY=9
SEASON_GREEN_RAMP_START_MULT=0.18
SEASON_GREEN_MULT_WINTER=0.08
SEASON_GREEN_MULT_EARLY_SPRING=0.18
SEASON_GREEN_MULT_GREEN=1.0
SEASON_GREEN_MULT_LATE_AUTUMN=0.42
SEASON_TREE_HEAT_MULT_WINTER=0.12
SEASON_TREE_HEAT_MULT_EARLY_SPRING=0.28
SEASON_TREE_HEAT_MULT_SPRING_RAMP=0.55
SEASON_TREE_HEAT_MULT_GREEN=1.0
SEASON_TREE_HEAT_MULT_LATE_AUTUMN=0.45
# Ступени снега (физика): пороги глубины м и снегопада см/ч + множители см. services/seasonal.py
SNOW_DEPTH_TIER0_MAX_M=0.02
SNOW_DEPTH_TIER1_MAX_M=0.05
SNOW_DEPTH_TIER2_MAX_M=0.10
SNOW_FRESH_TIER0_MAX_CM_H=0.2
SNOW_FRESH_TIER1_MAX_CM_H=1.0
SNOW_FRESH_TIER2_MAX_CM_H=3.0
# Зимняя heat-ветка: ослабить «летнюю» тень деревьев, усилить открытость/ветер при snow_model_strength.
WINTER_HEAT_OPEN_SCALE_WINTER=1.18
WINTER_HEAT_WIND_SCALE_WINTER=1.22
WEATHER_STRESS_EDGE_SNOW_OPEN=0.18
WEATHER_STRESS_EDGE_SNOW_SURFACE=0.22
WEATHER_STRESS_EDGE_SNOW_STAIRS=0.16
# Архив/historical: snow_depth — модельная величина, не точное состояние конкретного тротуара.

# Пакетные эксперименты (после precache_area):
#   python -m bike_router.tools.route_variants_experiment   # 6 вариантов, одна погода
#   python -m bike_router.tools.heat_weather_experiment     # только heat; --grid summer|winter

# --- Progressive POST /alternatives/start (фаза 1: shortest+full; фон: green,heat,stress,heat_stress) ---
PROGRESSIVE_ALTERNATIVES_ENABLED=false
PROGRESSIVE_BACKGROUND_VARIANTS=green,heat,stress,heat_stress
ALTERNATIVES_JOB_TTL_SEC=1800

# --- API / frontend ---
CORS_ALLOW_ORIGINS=*
BIKE_ROUTER_PORT=8000
# BIKE_ROUTER_HOST=127.0.0.1

# --- Surface AI ---
SURFACE_AI_ENABLED=false
SURFACE_AI_MODE=experiment
SURFACE_AI_TARGET=concrete
SURFACE_AI_MIN_CLASS_COUNT=50
SURFACE_AI_CONCRETE_TARGET_MODE=compact
SURFACE_AI_GROUP_TARGET_MODE=3class_unpaved_hard_to_soft
SURFACE_AI_TRAIN_DIRECT_GROUP_MODEL=true

SURFACE_AI_MODEL_CANDIDATES=always_majority,highway_heuristic,osm_only_rf,satellite_only_rf,combined_rf,combined_rf_balanced,combined_rf_without_spatial_prior,combined_rf_balanced_without_spatial_prior,combined_rf_with_neighbors
SURFACE_AI_GROUP_MODEL_CANDIDATES=group_direct_always_majority,group_direct_highway_heuristic,group_direct_osm_only_rf,group_direct_satellite_only_rf,group_direct_combined_rf,group_direct_combined_rf_balanced,group_direct_combined_rf_calibrated,group_direct_combined_rf_without_spatial_prior,group_direct_combined_rf_balanced_without_spatial_prior,group_direct_combined_rf_neighbor_features
SURFACE_AI_SELECTION_METRIC=macro_f1_safe
SURFACE_AI_DANGEROUS_ERROR_PENALTY=0.5
SURFACE_AI_MIN_BAD_SURFACE_RECALL=0.5
# Пост-обработка топ-1 по proba (paved_rough / unpaved_soft) только для кандидата ``*threshold_tuned*``; остальные group-direct без неё.
SURFACE_AI_GROUP_THRESHOLD_TUNING=true
SURFACE_AI_PAVED_ROUGH_MIN_PROBA=0.30
SURFACE_AI_UNPAVED_SOFT_MIN_PROBA=0.35

SURFACE_AI_CALIBRATION_ENABLED=true
SURFACE_AI_CALIBRATION_METHOD=sigmoid
SURFACE_AI_CALIBRATION_SHARE=0.1
SURFACE_AI_CALIBRATION_MIN_CLASS_COUNT=20

SURFACE_AI_ENABLE_SPATIAL_PRIOR=true
SURFACE_AI_RUN_SPATIAL_PRIOR_ABLATION=true

SURFACE_AI_USE_NEIGHBOR_FEATURES=true
SURFACE_AI_NEIGHBOR_HOPS=2
SURFACE_AI_NEIGHBOR_USE_PREDICTION_PASS2=true

SURFACE_AI_GRAPH_SOURCE_PRIORITY=area_precache,tiles_coverage_graph,osmnx_fallback
SURFACE_AI_STRICT_AREA_PRECACHE=false
SURFACE_AI_USE_TILE_COVERAGE_POLYGON=true
SURFACE_AI_TILE_USAGE_REPORT=true
SURFACE_AI_USE_GREEN_CACHE_FEATURES=true
SURFACE_AI_USE_TILE_GREEN_MASK_FEATURES=true

# --- Surface AI train/predict areas ---
SURFACE_AI_TRAIN_AREA_MODE=tile_coverage
SURFACE_AI_PREDICT_AREA_MODE=precache_polygon
SURFACE_AI_TRAIN_ON_ALL_TILE_EDGES=true
SURFACE_AI_PREDICT_ONLY_INSIDE_POLYGON=true

# --- Surface AI graph sources ---
SURFACE_AI_TRAIN_GRAPH_SOURCE_PRIORITY=tile_coverage_graph,area_precache,osmnx_fallback
SURFACE_AI_PREDICT_GRAPH_SOURCE_PRIORITY=area_precache,tile_coverage_graph,osmnx_fallback
SURFACE_AI_OSMNX_RETAIN_ALL=true
SURFACE_AI_OSMNX_TRUNCATE_BY_EDGE=true
SURFACE_AI_OSMNX_SIMPLIFY=true
SURFACE_AI_OSMNX_NETWORK_TYPE=all
SURFACE_AI_OSMNX_CUSTOM_FILTER=

# --- Surface AI holdout inside predict polygon ---
SURFACE_AI_HOLDOUT_PREDICT_POLYGON_KNOWN_SHARE=0.2

# --- Surface AI tile matching ---
SURFACE_AI_TILE_EDGE_MATCH_MODE=samples_and_buffer
SURFACE_AI_EDGE_TILE_BUFFER_M=10

# --- Surface AI compact experiment output ---
SURFACE_AI_COMPACT_OUTPUT=true
SURFACE_AI_MAX_OUTPUT_FILES=20
SURFACE_AI_SAVE_FULL_PREDICTIONS_GEOJSON=false

SURFACE_AI_USE_SATELLITE_FEATURES=true
SURFACE_AI_SAMPLE_STEP_M=7
SURFACE_AI_PIXEL_WINDOW=5
SURFACE_AI_TMS_SERVER=google
SURFACE_AI_TILE_ZOOM=20
SURFACE_AI_TILES_DIR=

SURFACE_AI_SPATIAL_GRID_M=300
SURFACE_AI_TEST_SHARE=0.2
SURFACE_AI_RANDOM_STATE=42

SURFACE_AI_RF_N_ESTIMATORS=300
SURFACE_AI_RF_CLASS_WEIGHT=balanced_subsample

SURFACE_AI_MIN_CONFIDENCE=0.65
SURFACE_AI_CONF_HIGH=0.85
SURFACE_AI_CONF_MEDIUM=0.65
SURFACE_AI_ENABLE_SAFETY_POLICY=true
SURFACE_AI_PAVED_GOOD_MIN_CONFIDENCE=0.90
SURFACE_AI_BAD_SURFACE_MIN_CONFIDENCE=0.60
SURFACE_AI_MIN_MARGIN=0.15
SURFACE_AI_MAX_DANGEROUS_UPGRADE_RATE_EFFECTIVE=0.10
SURFACE_AI_MAX_CALIBRATION_ECE=0.08

SURFACE_AI_OUT_DIR=./data/experiments/surface_ai
