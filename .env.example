# ═══════════════════════════════════════════════════════════════════
# Bike Router — .env для area precache внутри полигона
# Цель: corridor mode + заранее собранный area cache по полигону
# ═══════════════════════════════════════════════════════════════════

# --- Каталог данных ---
# Если переменную не задавать: кэш в подкаталоге репозитория bike_router/data/ (cache, osmnx_cache).
# Две папки на диске бывают, когда здесь R:\data, а дефолт пишет в bike_router/data — задайте ОДИН путь.
# Docker: ./data → /data (docker-compose); локально можно: BIKE_ROUTER_BASE_DIR=./data (из каталога bike_router).
# В Docker compose обычно задаётся через environment: /data (см. docker-compose.yml).
BIKE_ROUTER_BASE_DIR=/data

# --- Основной режим: только коридор ---
GRAPH_CORRIDOR_MODE=true

# Фиксированную зону НЕ включать, иначе отключится dynamic corridor graph
AREA_MIN_LAT=0
AREA_MAX_LAT=0
AREA_MIN_LON=0
AREA_MAX_LON=0
# AREA_POLYGON_WKT не задавать

# --- Area precache (граф по PRECACHE_AREA_POLYGON_WKT; отдельно от corridor_graphs) ---
# Данные: {BIKE_ROUTER_BASE_DIR}/cache/area_precache/<hash>/ — в git не коммитить (см. .gitignore: data/).
# Идемпотентность: при обрыве удалите *.tmp в этой папке или перезапустите precache_area.
# Сборка только офлайн: python -m bike_router.tools.precache_area (до docker compose up).
# PRECACHE_AREA_BUILD_ON_STARTUP — устарело для эксплуатации; держите false.
PRECACHE_AREA_ENABLED=true
PRECACHE_AREA_NAME=samara_polygon
PRECACHE_AREA_BUILD_ON_STARTUP=false
PRECACHE_AREA_USE_GREEN_GRAPH=true

PRECACHE_AREA_POLYGON_WKT=POLYGON ((50.059976577758796 53.17022361212237, 50.06375312805176 53.168782979028286, 50.07164955139161 53.16168200928214, 50.05036354064942 53.14696176585667, 50.049505233764656 53.12276019294606, 50.07765769958497 53.10091558676632, 50.113191604614265 53.12389333666635, 50.172586441040046 53.124820432036195, 50.20322799682618 53.16279965375739, 50.200824737548835 53.17597119238269, 50.31549453735352 53.211760877628045, 50.30313491821289 53.260050107861275, 50.19189834594727 53.28201907379596, 50.17301559448243 53.25080745062705, 50.15001296997071 53.227178252658206, 50.10143280029297 53.206238180570836, 50.076456069946296 53.189564571215946, 50.059976577758796 53.17022361212237))

# --- Corridor параметры ---
BUFFER=0.003
CORRIDOR_BUFFER_METERS=400

# Не основной режим: прогрев коридора по START/END из .env при старте API (отдельно от area precache).
CORRIDOR_WARMUP_PREBUILD=false

# --- Demo START/END ---
START_LAT=53.186243
START_LON=50.088031
END_LAT=53.195334
END_LON=50.124063

# --- Спутниковый анализ ---
DISABLE_SATELLITE_GREEN=false
ANALYZE_CORRIDOR=true
ROAD_BUFFER_METERS=10
TILE_DOWNLOAD_THREADS=16
# Пакеты тайлов для зелени (меньше — меньше RAM при precache / большом полигоне). 0 = без разбиения.
GREEN_TILE_BATCH_SIZE=4096
# google — по умолчанию в config; при недоступности mt.google.com по DNS используйте esri
TMS_SERVER=google
# Серые/плоские тайлы не пишем в cache/tiles и не считаем «готовым» edge-кэш зелени
TILE_VALIDATE_FOR_GREEN=true

# Если хочешь явно зафиксировать zoom, раскомментируй:
# SATELLITE_ZOOM=19

# --- Кэши ---
GEOCODE_DISK_CACHE=true
# Опциональный UX-кэш JSON ответов; не обязателен для корректности маршрутов.
ROUTE_DISK_CACHE=false
CACHE_SATELLITE=true
CACHE_TILE_ANALYSIS=true
FORCE_RECALCULATE=false
# green_edges/*.pkl: смена схемы в коде инвалидирует старые файлы; при «залипших» нулях — удалить cache/green_edges/
# или FORCE_RECALCULATE=true. GREEN_EDGE_REJECT_ALL_ZERO_CACHE=false — доверять полностью нулевому pickle (редко).

# --- Overpass ---
# Порядок важен: при сбое первого идёт следующий. overpass-api.de обычно стабильнее частных зеркал.
OSM_OVERPASS_URLS=https://overpass-api.de/api,https://overpass.kumi.systems/api
OSM_OVERPASS_RATE_LIMIT=false
OSM_REQUESTS_TIMEOUT=180
OSM_OVERPASS_FIRST_TIMEOUT=20
OVERPASS_PER_ENDPOINT_RETRIES=2

# --- Лимиты ---
MAX_ROUTE_KM=50
MAX_SNAP_DISTANCE_M=500

# --- API / frontend ---
CORS_ALLOW_ORIGINS=*
BIKE_ROUTER_PORT=8000
# BIKE_ROUTER_HOST=127.0.0.1