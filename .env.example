# ═══════════════════════════════════════════════════════════════════
# Bike Router — пример окружения
# Скопируйте в .env и отредактируйте под свой сервер / город.
# ═══════════════════════════════════════════════════════════════════

# --- Рекомендуемый сценарий для предсказуемого первого старта ---
#
# Продакшен с заранее известной зоной города:
#   GRAPH_CORRIDOR_MODE=false  +  AREA_* или AREA_POLYGON_WKT
#   → граф и SRTM поднимаются в warmup(), первый POST не тянет Overpass.
#
# Демо «коридор только по точкам запроса» (ниже GRAPH_CORRIDOR_MODE=true):
#   первый запрос с произвольными точками может инициировать долгую загрузку OSM;
#   CORRIDOR_WARMUP_PREBUILD лишь прогревает коридор вокруг START/END из этого файла —
#   он не покрывает все возможные пары точек на карте. Для стенда подставьте в .env
#   START/END близко к тем же координатам, что тестируете в UI, или увеличьте таймаут прокси.

# --- Обязательность переменных ---
# Для запуска API ни одна переменная не обязательна: есть значения по умолчанию.
#
# Режим «только коридор по POST» (динамический граф между точками ± CORRIDOR_BUFFER_METERS или ± BUFFER):
#   • GRAPH_CORRIDOR_MODE=true
#   • НЕ задавайте AREA_POLYGON_WKT и НЕ задавайте ненулевой AREA_* — иначе коридор отключится.
#   • Приоритет в коде: AREA_POLYGON_WKT → AREA_* → GRAPH_CORRIDOR_MODE → demo START/END+BUFFER.
#
# Фиксированная зона города:
#   • задайте AREA_* и/или AREA_POLYGON_WKT; GRAPH_CORRIDOR_MODE оставьте false или не задавайте.
#
# Docker: при необходимости BIKE_ROUTER_BASE_DIR=/data (в compose уже /data).

# --- Каталог данных (кэш тайлов, OSMnx, дисковые кэши) ---
# BIKE_ROUTER_BASE_DIR=/data

# --- Режим коридора (граф и спутник по точкам POST ± BUFFER) ---
GRAPH_CORRIDOR_MODE=true
# Готовые взвешенные графы коридоров в cache/corridor_graphs/*.graphml (ключ: bbox + настройки зелени/весов).
# CORRIDOR_GRAPH_DISK_CACHE=true
# Сетка для ключа кэша коридора (~0.001° ≈ 111 м по широте; в коде по умолчанию 0.001). 0 — только round(..., 6).
# CORRIDOR_CACHE_GRID_STEP_DEG=0.001

# Без фиксированной области (обязательно для работы коридора):
AREA_MIN_LAT=0
AREA_MAX_LAT=0
AREA_MIN_LON=0
AREA_MAX_LON=0
# AREA_POLYGON_WKT не задавать

# --- Фиксированная область (отключите коридор: GRAPH_CORRIDOR_MODE=false) ---
# 1) Полигон WKT (lon lat), приоритет над AREA_*:
# AREA_POLYGON_WKT=POLYGON ((50.08 53.18, 50.22 53.18, 50.22 53.26, 50.08 53.26, 50.08 53.18))
#
# 2) Прямоугольник:
# AREA_MIN_LAT=53.18
# AREA_MAX_LAT=53.26
# AREA_MIN_LON=50.08
# AREA_MAX_LON=50.22

# Демо START/END — для коридора на форму графа не влияют; без коридора и без AREA — bbox вокруг этой пары.
START_LAT=53.186243
START_LON=50.088031
END_LAT=53.195334
END_LON=50.124063
BUFFER=0.003
# При GRAPH_CORRIDOR_MODE по умолчанию в коде 400 м (см. config). Явно задать или переопределить:
CORRIDOR_BUFFER_METERS=400
# Поставьте 0, если нужен только BUFFER в градусах (лог: ±BUFFER=…°).

# --- Авторасширение коридора при NO_PATH (узкий граф / нет пути в bbox) ---
# Шаг добавки к буферу коридора (м) на каждую попытку; не более N попыток; верхняя граница суммарной добавки (м).
# AUTO_EXPAND_STEP_METERS=1000
# AUTO_EXPAND_MAX_ATTEMPTS=5
# AUTO_EXPAND_MAX_METERS=5000

# --- Progressive alternatives (job_id + polling) ---
# TTL записей задач (сек), затем GET /alternatives/job/{id} вернёт 404.
# ALTERNATIVES_JOB_TTL_SEC=1800

# --- GRAPH_CORRIDOR_MODE: предзагрузка графа по START/END из .env при старте API (ускоряет первый демо-запрос) ---
# CORRIDOR_WARMUP_PREBUILD=true
# --- HTTP retry (Overpass, Nominatim, TMS) ---
# HTTP_RETRY_MAX_ATTEMPTS=4
# HTTP_RETRY_BASE_DELAY_SEC=0.5
# HTTP_RETRY_MAX_DELAY_SEC=30
# HTTP_RETRY_JITTER=0.25
# Повторы на одном mirror Overpass перед переключением на следующий URL.
# OVERPASS_PER_ENDPOINT_RETRIES=3

# --- Overpass (OSMnx) — если «висит» на «Загрузка дорог из OSM» из Docker ---
# OSMnx перед запросом может ждать слот по /status; при недоступности статуса — пауза до 60 с без ваших логов.
# По умолчанию в коде rate_limit=false; явно:
# OSM_OVERPASS_RATE_LIMIT=false
# Таймаут HTTP к Overpass (сек, целое; в запрос Overpass уходит как целое число):
# OSM_REQUESTS_TIMEOUT=180
# Несколько URL через запятую — последовательный fallback (рекомендуется для демо: не зависеть от одного зеркала):
# OSM_OVERPASS_URLS=https://overpass.kumi.systems/api,https://overpass-api.de/api
# Короткий таймаут только для первого endpoint в списке (сек); 0 — везде OSM_REQUESTS_TIMEOUT:
# OSM_OVERPASS_FIRST_TIMEOUT=30
# Один URL (если OSM_OVERPASS_URLS не задан): без завершающего /interpreter
# OSM_OVERPASS_URL=https://overpass-api.de/api

# --- Лимиты маршрутизации ---
# MAX_ROUTE_KM=50
# MAX_SNAP_DISTANCE_M=500

# --- Инвалидация кэшей (маршруты + графы коридоров включают отпечаток весов) ---
# ROUTING_ALGO_VERSION=1

# --- Кэши ---
# GEOCODE_DISK_CACHE=true
# ROUTE_DISK_CACHE=true
# CACHE_SATELLITE=true
# CACHE_TILE_ANALYSIS=true
# FORCE_RECALCULATE=false

# --- Спутниковый анализ (озеленение) ---
# SATELLITE_ZOOM=17
# ROAD_BUFFER_METERS=10
# ANALYZE_CORRIDOR=true
# TILE_DOWNLOAD_THREADS=8
# TMS_SERVER=google
# DISABLE_SATELLITE_GREEN=false

# --- HTTP (production) ---
# Список origin через запятую; по умолчанию — * (dev). При явных origin включается allow_credentials.
# CORS_ALLOW_ORIGINS=https://example.com,https://www.example.com

# --- Локальный запуск (python -m bike_router) ---
# По умолчанию в коде: 0.0.0.0 — доступ с телефона в LAN: http://<ipconfig IPv4>:8000
# BIKE_ROUTER_PORT=8000
# Только с этого ПК (без LAN):
# BIKE_ROUTER_HOST=127.0.0.1
